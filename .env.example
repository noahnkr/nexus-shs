# Nexus configuration. Copy to .env and fill in.

# --- core ---
NEXUS_ENV=dev                      # dev | prod  (prod fails fast on missing secrets)
VAULT_PATH=./vault                 # the one volume the service binds
PUBLIC_URL=http://localhost:8000   # used to build webhook callback URLs

# --- auth ---
MCP_TOKEN=changeme-mcp-bearer      # bearer for the MCP endpoint
CRON_TOKEN=changeme-cron-bearer    # bearer for POST /cron/{job}

# --- models ---
ANTHROPIC_API_KEY=sk-ant-...       # Messages API for the agent loop + ingest classify
# Embeddings are OPTIONAL — leave unset to run BM25-only (semantic search stays dormant)
EMBEDDING_API_KEY=

# --- per-source connector secrets (one per connectors/<source>/) ---
EXAMPLE_WEBHOOK_SECRET=            # HMAC secret for connectors/example (sample only)
WELCOMEHOME_API_KEY=               # WelcomeHome Exports API — see docs/connectors/welcomehome.md
GOTO_CONNECT_CLIENT_ID=            # GoTo Connect OAuth2 — see docs/connectors/goto-connect.md
GOTO_CONNECT_CLIENT_SECRET=        # bootstrap tokens with: python scripts/goto_oauth.py authorize
GOTO_CONNECT_WEBHOOK_SECRET=       # unused unless a webhook-channel backstop is wired (push is WS)

# --- owner notifications ---
OWNER_CONTACT=brennen@shsgreaternaperville.com,+16304843579  # email + SMS for Brennen Roberts
