# Nexus configuration (§7 step 8). Copy to .env and fill in.

# --- core ---
NEXUS_ENV=dev                      # dev | prod  (prod fails fast on missing secrets)
VAULT_PATH=./vault                 # the one volume the service binds
PUBLIC_URL=http://localhost:8000   # used to build webhook callback URLs

# --- auth ---
MCP_TOKEN=changeme-mcp-bearer      # bearer for the MCP endpoint
CRON_TOKEN=changeme-cron-bearer    # bearer for POST /cron/{job}

# --- models ---
ANTHROPIC_API_KEY=sk-ant-...       # Messages API for the agent loop + ingest classify
# Embeddings are OPTIONAL — leave unset to run BM25-only (semantic dormant, §3.4)
EMBEDDING_API_KEY=

# --- per-source connector secrets (one per connectors/<source>/) ---
EXAMPLE_WEBHOOK_SECRET=            # HMAC secret for connectors/example

# --- owner notifications (§4.4) ---
OWNER_CONTACT=                     # phone/email/push target for notify(owner, ...)
